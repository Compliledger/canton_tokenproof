# TokenProof Backend — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Canton JSON Ledger API v2 base URL
# Local sandbox: http://localhost:6864
# DevNet / TestNet: set to your participant node URL
CANTON_LEDGER_API_URL=http://localhost:6864

# JWT bearer token for the evaluator user
# Leave empty for local sandbox (sandbox runs in no-auth / wildcard mode)
# In production: obtain from your Canton participant node's auth service
CANTON_EVALUATOR_JWT=

# Fully-qualified evaluator party identifier
# Format: DisplayName::1220<fingerprint>
# Obtain by running: curl http://localhost:6864/v2/parties
CANTON_EVALUATOR_PARTY=TokenProofEvaluator::1220<fingerprint>

# DAML package ID of the deployed tokenproof-canton DAR
# Obtain from .daml/dist/ after dpm build, or from:
#   curl http://localhost:6864/v2/packages | python3 -c "import sys,json; [print(p) for p in json.load(sys.stdin)['packageIds']]"
TOKENPROOF_PACKAGE_ID=
