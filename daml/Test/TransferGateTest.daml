module Test.TransferGateTest where

import Daml.Script
import DA.Time
import DA.Date
import Main.ComplianceProof
import Main.Types

-- | Minimal tokenized bond used only within this test module.
-- The production reference implementation lives in examples/cip0056-gated-transfer/.
template TestBond
  with
    issuer    : Party
    owner     : Party
    evaluator : Party
    assetId   : Text
  where
    signatory issuer
    observer  owner, evaluator

    -- Transfer enforces the compliance gate atomically.
    -- Canton 3.4: caller passes proofCid explicitly; fetch on an archived
    -- or Revoked proof aborts the entire transaction.
    choice Transfer : ContractId TestBond
      with
        newOwner : Party
        proofCid : ContractId ComplianceProof
      controller owner
      do
        proof <- fetch proofCid
        assertMsg
          ("Transfer blocked: compliance proof status is " <> show proof.decisionStatus)
          (proof.decisionStatus == Active)
        create this with owner = newOwner

-- | Critical enforcement test: proves the compliance gate actually blocks
-- transfers when a proof is Revoked. submitMustFail is the definitive assertion.
-- Run with: dpm test
transferGateTest : Script ()
transferGateTest = do
  issuer    <- allocateParty "BondIssuer"
  buyer     <- allocateParty "Buyer"
  evaluator <- allocateParty "TokenProofEvaluator"

  let assetId  = "BOND-GS-2026-001"
  let baseTime = time (date 2026 Apr 13) 0 0 0

  -- Create an Active compliance proof for the bond.
  proofCid <- submitMulti [issuer, evaluator] [] $ createCmd ComplianceProof with
    assetId        = assetId
    issuer         = issuer
    evaluator      = evaluator
    regulator      = None
    classification = "digital_security"
    policyVersion  = "SEC_CLASSIFICATION_v1"
    decisionStatus = Active
    proofHash      = "sha256:bondHash123"
    timestamp      = baseTime

  -- Create the bond held by the issuer (both signatories are the same party).
  bondCid <- submit issuer $ createCmd TestBond with
    issuer    = issuer
    owner     = issuer
    evaluator = evaluator
    assetId   = assetId

  -- Transfer SUCCEEDS — proof is Active; pass proofCid explicitly.
  buyerBondCid <- submit issuer $ exerciseCmd bondCid Transfer with
    newOwner = buyer
    proofCid = proofCid

  -- Evaluator revokes the proof (e.g. SEC investigation opened).
  -- RevokeProof archives old contract, returns new one with Revoked status.
  revokedCid <- submit evaluator $ exerciseCmd proofCid RevokeProof

  -- Transfer FAILS — submitMustFail confirms atomic enforcement.
  -- revokedCid has decisionStatus = Revoked — assertMsg fires and aborts tx.
  submitMustFail buyer $ exerciseCmd buyerBondCid Transfer with
    newOwner = issuer
    proofCid = revokedCid

  return ()
